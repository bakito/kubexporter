                        "range": false
                      }
                    },
                    "refId": "Query Duration",
                    "hidden": false
                  }
                },
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "prometheus",
                      "version": "v0",
                      "datasource": {
                        "name": "${datasource}"
                      },
                      "spec": {
                        "editorMode": "code",
                        "expr": "last_over_time(kubexporter_resource_export_duration_seconds{cluster=~\"$cluster\", target=~\"$target\"}[2d])",
                        "format": "table",
                        "instant": true,
                        "legendFormat": "Export Time",
                        "range": false
                      }
                    },
                    "refId": "Export Duration",
                    "hidden": false
                  }
                }
              ],
              "transformations": [
                {
                  "kind": "Transformation",
                  "group": "filterFieldsByName",
                  "spec": {
                    "options": {
                      "include": {
                        "names": [
                          "group",
                          "kind",
                          "namespaced",
                          "version",
                          "Value #Total Instances",
                          "Value #Exported Instances",
                          "Value #Exported Size",
                          "Value #Query Duration",
                          "Value #Export Duration"
                        ]
                      }
                    }
                  }
                },
                {
                  "kind": "Transformation",
                  "group": "merge",
                  "spec": {
                    "options": {}
                  }
                },
                {
                  "kind": "Transformation",
                  "group": "organize",
                  "spec": {
                    "options": {
                      "excludeByName": {},
                      "includeByName": {},
                      "indexByName": {},
                      "renameByName": {
                        "Export Time": "Export Duration",
                        "Exported": "Exported Instances",
                        "Found": "Found Instances",
                        "Query Time": "Query Duration",
                        "Size": "Exported Size",
                        "Value #Export Duration": "Export Duration",
                        "Value #Exported Instances": "Exported Instances",
                        "Value #Exported Size": "Exported Size",
                        "Value #Query Duration": "Query Duration",
                        "Value #Total Instances": "Total Instances",
                        "error": "Error",
                        "group": "Group",
                        "kind": "Kind",
                        "namespaced": "Namespaced",
                        "resource": "Resource",
                        "version": "Version"
                      }
                    }
                  }
                }
              ],
              "queryOptions": {}
            }
          },
          "vizConfig": {
            "kind": "VizConfig",
            "group": "table",
            "version": "13.2.0-29004967847",
            "spec": {
              "options": {
                "cellHeight": "sm",
                "showHeader": true,
                "sortBy": []
